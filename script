task.spawn(function()
    while task.wait(0.1) do
        if Settings.AutoTake and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            for _, v in ipairs(Workspace:GetDescendants()) do
                if v:IsA("ProximityPrompt") then
                    local objT, actT = v.ObjectText:lower(), v.ActionText:lower()
                    local name = v.Name:lower()
                    local parentName = v.Parent and v.Parent.Name:lower() or ""
                    
                    local isBad = objT:find("robux") or actT:find("robux") or objT:find("r%$") or
                                  name:find("buy") or name:find("trade") or objT:find("trade") or 
                                  actT:find("buy") or name:find("pass") or parentName:find("buy") or
                                  actT:find("trade")
                                  
                    local isHuman = v.Parent:FindFirstAncestorOfClass("Model") and v.Parent:FindFirstAncestorOfClass("Model"):FindFirstChild("Humanoid")

                    if not (isBad or isHuman) and name ~= "place brainrot" then
                        if (player.Character.HumanoidRootPart.Position - v.Parent.Position).Magnitude < Settings.Range then
                            v.HoldDuration = 0
                            fireproximityprompt(v)
                        end
                    end
                end
            end
        end
    end
end)

