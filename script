local function drag(f, h) 
    local s, st, p 
    h.InputBegan:Connect(function(i) 
        if i.UserInputType == Enum.UserInputType.MouseButton1 then 
            s=true st=i.Position p=f.Position 
        end 
    end) 
    UIS.InputChanged:Connect(function(i) 
        if s and i.UserInputType == Enum.UserInputType.MouseMovement then 
            local d=i.Position-st 
            f.Position=UDim2.new(p.X.Scale, p.X.Offset+d.X, p.Y.Scale, p.Y.Offset+d.Y) 
        end 
    end) 
    UIS.InputEnded:Connect(function(i) 
        if i.UserInputType == Enum.UserInputType.MouseButton1 then s=false end 
    end) 
end

